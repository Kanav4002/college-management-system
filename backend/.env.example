# ── Server ────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated origins allowed to call the API.
# Include your deployed Vercel frontend exactly, without a trailing slash.
CORS_ORIGINS=http://localhost:5173,https://uni-sphere-five.vercel.app

# Used to build password-reset links sent to users in dev (logged to console).
FRONTEND_URL=https://uni-sphere-five.vercel.app

# ── Database (MongoDB) ────────────────────
# Local Mongo:    mongodb://127.0.0.1:27017/unisphere
# Mongo Atlas:    mongodb+srv://<user>:<pass>@<cluster>/unisphere
MONGO_URI=mongodb://127.0.0.1:27017/unisphere

# ── JWT ──────────────────────────────────
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=1d

# ── Google OAuth (optional) ───────────────
# Use the same OAuth Client ID you configured for the frontend.
# Leave blank to disable backend verification (frontend will hide the button).
GOOGLE_CLIENT_ID=291479364432-rql3lhqo2ram2ehqim4s3d1a14pif6pf.apps.googleusercontent.com
